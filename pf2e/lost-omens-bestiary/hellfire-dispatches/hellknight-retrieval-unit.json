        {
            "_id": "XUnUiVbgStOiWsis",
            "img": "systems/pf2e/icons/actions/TwoActions.webp",
            "name": "Coordinated Subdual",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The retrieval unit's last action was a Whirling Onslaught that dealt damage to at least one creature of Medium size or smaller</p><hr /><p><strong>Effect</strong> The unit attempts a single Athletics check to [[/act grapple]], comparing the result to the Fortitude DC of each creature that they currently have @UUID[Compendium.pf2e.conditionitems.Item.Grabbed] or @UUID[Compendium.pf2e.conditionitems.Item.Restrained] or was damaged by the required Whirling Onslaught. It can target up to a maximum number of creatures equal to double the troop's current number of segments.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
