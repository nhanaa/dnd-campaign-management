            "name": "Disarming Twist",
            "sort": 300000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The crew's previous action was a Scurvy Strike that dealt damage to at least one enemy</p><hr /><p><strong>Effect</strong> The crew uses their weapons to knock the weapons out of their enemies' hands. The crew attempts a single Athletics check to [[/act disarm]], comparing the result to the Reflex DC of each creature that was damaged by the required Scurvy Strike. If the result is a critical failure, the crew gets a failure instead.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
