        {
            "_id": "kbG9Fa6ZVowLwyWQ",
            "img": "systems/pf2e/icons/actions/TwoActions.webp",
            "name": "Unleash Hell",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The champions draw or reload their longbows, then launch a ranged attack in the form of a volley. This volley is a @Template[type:burst|distance:10] within 100 feet that deals @Damage[5d8[piercing]|options:area-damage] damage (@Check[reflex|dc:27|basic] save). When the troop is reduced to 2 segments, this area decreases to a @Template[type:burst|distance:5].</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [],
                "slug": null,
