            },
            "type": "action"
        },
        {
            "_id": "OLEJJ0mQLPObNyBr",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Faces in the Crowd",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Twilight Talon infiltrators are masters of blending into and dispersing seamlessly among large groups. While disguised as noncombatants, they can move into other creatures' spaces, and other creatures can move into the team's spaces.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
