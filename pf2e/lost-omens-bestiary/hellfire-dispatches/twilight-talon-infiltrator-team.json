        {
            "_id": "3aieAwMZYHygv9wU",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Undercover",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>By spending 2 hours preparing disguises, performing reconnaissance, and the like, the infiltrators can convincingly impersonate any troop unit of their level or lower that has the humanoid trait. Alternatively, they can disguise themselves as a mixed assortment of humanoid noncombatants who don't obviously form a cohesive unit. This functions as the Impersonate action with the infiltrators gaining a +2 circumstance bonus to their Deception DC. Infiltrators can't use Undercover to appear as specific individuals, nor can they impersonate groups that require resources unavailable to them, at the GM's discretion (impersonating a cavalry unit without access to mounts, for example).</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "RollOption",
                        "option": "undercover",
                        "toggleable": true
                    },
                    {
                        "key": "FlatModifier",
                        "predicate": [
                            "undercover"
                        ],
                        "selector": [
                            "deception-dc"
                        ],
                        "type": "circumstance",
                        "value": 2
                    }
                ],
                "slug": null,
                "traits": {
                    "value": [
                        "concentrate",
                        "exploration",
                        "manipulate",
                        "secret"
                    ]
                }
            },
            "type": "action"
        },
        {
            "_id": "rxoWm9immyT5ileK",
            "img": "systems/pf2e/icons/actions/OneThreeActions.webp",
            "name": "Blindside",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><span class=\"action-glyph\">1</span> to <span class=\"action-glyph\">3</span></p>\n<p><strong>Frequency</strong> once per round</p><hr /><p><strong>Effect</strong> The infiltrators strike against enemies in a @Template[type:emanation|distance:5], dealing damage of a type appropriate to any weapons or implements incorporated into their disguise, with a @Check[reflex|dc:23|basic] save. The damage depends on the number of actions.</p>\n<p><span class=\"action-glyph\">1</span> @Damage[(1d8+1)[bludgeoning]]{1d8+1 bludgeoning, piercing, or slashing damage}</p>\n<p><span class=\"action-glyph\">2</span> @Damage[(2d8+8)[bludgeoning]]{2d8+8 bludgeoning, piercing, or slashing damage}</p>\n<p><span class=\"action-glyph\">3</span> @Damage[(3d8+9)[bludgeoning]]{3d8+9 bludgeoning, piercing, or slashing damage}</p>"
                },
                "frequency": {
                    "max": 1,
                    "per": "round"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "alwaysActive": true,
                        "key": "RollOption",
                        "option": "blindside",
                        "selection": "bludgeoning",
                        "suboptions": [
                            {
                                "label": "PF2E.TraitBludgeoning",
                                "value": "bludgeoning"
                            },
                            {
                                "label": "PF2E.TraitPiercing",
                                "value": "piercing"
                            },
                            {
                                "label": "PF2E.TraitSlashing",
                                "value": "slashing"
                            }
                        ],
                        "toggleable": true,
                        "value": true
                    },
                    {
                        "key": "DamageAlteration",
                        "mode": "override",
                        "predicate": [
                            "damage:type:bludgeoning"
                        ],
                        "property": "damage-type",
                        "selectors": [
                            "{item|id}-inline-damage"
                        ],
                        "value": "{item|flags.system.rulesSelections.blindside}"
                    }
                ],
                "slug": null,
